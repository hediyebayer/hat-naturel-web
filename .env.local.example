# hatoperasyon backend (rezervasyon API'si). Boş bırakılırsa fallback mock fiyat gösterilir.
# Örn: https://hatoperasyon.com (production), http://localhost:3000 (local)
HATOPERASYON_API_URL=
HATOPERASYON_PUBLIC_API_KEY=

# Resend (iletişim/rezervasyon email bildirimleri). Boş bırakılırsa console.log fallback.
RESEND_API_KEY=
CONTACT_EMAIL_TO=info@hatnaturel.com.tr

# Site URL (canonical/SEO)
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# Ödeme provider — gerçek tahsilatı belirler. Banka onayı + kimlik bilgileri gelene kadar 'mock'.
PAYMENT_PROVIDER=mock          # mock | vakifbank
# Ödeme GÖRÜNÜM modu (sadece UI). 'live' = DEMO filigranı gizli (banka denetimi/başvuru için).
# 'demo' = DEMO uyarıları görünür (geliştirme). Gerçek para PAYMENT_PROVIDER'a bağlı, buna değil.
NEXT_PUBLIC_PAYMENT_MODE=demo  # demo | live
NEXT_PUBLIC_DEPOSIT_RATIO=0.3
PAYMENT_EMAIL_TO=rezervasyon@hatnaturel.com.tr

# VAKIFBANK (TODO — banka onayından sonra doldurulacak)
VAKIFBANK_MERCHANT_ID=
VAKIFBANK_TERMINAL_ID=
VAKIFBANK_STORE_KEY=
VAKIFBANK_MPI_URL=https://onlineodemetest.vakifbank.com.tr:4443/MPIAPI/MPI_Enrollment.aspx
VAKIFBANK_3DSECURE_URL=https://3dsecure.vakifbank.com.tr:4443/MPIAPI/MPI_Enrollment.aspx
VAKIFBANK_ENV=test
